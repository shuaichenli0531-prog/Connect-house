# Environment Variables Template
# Copy this file to .env for local development

# Database
# Use the same PostgreSQL-style connection setup locally and in production.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Admin
ADMIN_SECRET="your-secret-password"

# For production deployment on Vercel:
# - DATABASE_URL should be set to your PostgreSQL connection string
# - DIRECT_URL should be set to your PostgreSQL direct connection
# - Configure these in Vercel Dashboard > Settings > Environment Variables
